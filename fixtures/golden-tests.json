{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "El Salvador Law MCP",
  "description": "Golden contract tests for the El Salvador Law MCP",
  "tests": [
    {
      "id": "SV-001",
      "category": "search",
      "description": "Search for 'datos personales' returns results",
      "tool": "search_legislation",
      "input": {
        "query": "datos personales",
        "limit": 5
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "text_not_empty": true
      }
    },
    {
      "id": "SV-002",
      "category": "negative",
      "description": "Negative test: non-existent law",
      "tool": "get_provision",
      "input": {
        "document_id": "NONEXISTENT_LAW_999",
        "provision_ref": "art999"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
